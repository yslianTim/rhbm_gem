@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Eigen3 REQUIRED)

if("@RHBM_GEM_USE_SYSTEM_CLI11@" STREQUAL "TRUE")
    find_dependency(CLI11 REQUIRED)
endif()

if("@RHBM_GEM_WITH_OPENMP@" STREQUAL "TRUE")
    if(APPLE AND CMAKE_CXX_COMPILER_ID STREQUAL "AppleClang")
        set(_RHBM_GEM_OPENMP_CANDIDATES)
        if("@RHBM_GEM_OPENMP_ROOT@" AND EXISTS "@RHBM_GEM_OPENMP_ROOT@/include/omp.h")
            list(APPEND _RHBM_GEM_OPENMP_CANDIDATES "@RHBM_GEM_OPENMP_ROOT@")
        endif()
        if(DEFINED ENV{HOMEBREW_PREFIX})
            list(APPEND _RHBM_GEM_OPENMP_CANDIDATES "$ENV{HOMEBREW_PREFIX}/opt/libomp")
        endif()
        list(APPEND _RHBM_GEM_OPENMP_CANDIDATES
            "/opt/homebrew/opt/libomp"
            "/usr/local/opt/libomp"
        )
        foreach(_RHBM_GEM_OPENMP_CANDIDATE IN LISTS _RHBM_GEM_OPENMP_CANDIDATES)
            if(EXISTS "${_RHBM_GEM_OPENMP_CANDIDATE}/include/omp.h")
                set(OpenMP_ROOT "${_RHBM_GEM_OPENMP_CANDIDATE}" CACHE PATH
                    "Root directory for OpenMP installation")
                list(PREPEND CMAKE_PREFIX_PATH "${_RHBM_GEM_OPENMP_CANDIDATE}")
                list(REMOVE_DUPLICATES CMAKE_PREFIX_PATH)
                break()
            endif()
        endforeach()
        unset(_RHBM_GEM_OPENMP_CANDIDATE)
        unset(_RHBM_GEM_OPENMP_CANDIDATES)
    endif()
    find_dependency(OpenMP REQUIRED COMPONENTS CXX)
endif()

if("@RHBM_GEM_WITH_BOOST@" STREQUAL "TRUE")
    set(_RHBM_GEM_BOOST_COMPONENTS "@RHBM_GEM_BOOST_COMPONENTS@")
    set(_RHBM_GEM_BOOST_FIND_ARGS)
    if(_RHBM_GEM_BOOST_COMPONENTS)
        list(APPEND _RHBM_GEM_BOOST_FIND_ARGS COMPONENTS ${_RHBM_GEM_BOOST_COMPONENTS})
    endif()

    find_dependency(Boost CONFIG QUIET ${_RHBM_GEM_BOOST_FIND_ARGS})
    if(NOT Boost_FOUND)
        if(POLICY CMP0167)
            cmake_policy(PUSH)
            cmake_policy(SET CMP0167 OLD)
            find_dependency(Boost REQUIRED ${_RHBM_GEM_BOOST_FIND_ARGS})
            cmake_policy(POP)
        else()
            find_dependency(Boost REQUIRED ${_RHBM_GEM_BOOST_FIND_ARGS})
        endif()
    endif()
endif()

if("@RHBM_GEM_WITH_ROOT@" STREQUAL "TRUE")
    find_dependency(ROOT REQUIRED COMPONENTS Core Hist Gpad RIO)
endif()

if("@RHBM_GEM_USE_SYSTEM_SQLITE3@" STREQUAL "TRUE")
    find_dependency(SQLite3 REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/RHBM_GEMTargets.cmake")

check_required_components(RHBM_GEM)

unset(_RHBM_GEM_BOOST_COMPONENTS)
unset(_RHBM_GEM_BOOST_FIND_ARGS)
